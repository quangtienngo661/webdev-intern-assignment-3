# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=g_scores
POSTGRES_HOST_PORT=5432

# API container
API_HOST_PORT=5000
CORS_ORIGIN=http://localhost:5173
SEED_FILE=/dataset/diem_thi_thpt_2024.csv
SEED_BATCH_SIZE=2000

# Web container
WEB_HOST_PORT=5173
VITE_API_URL=http://localhost:5000

# Useful when running the API from the host machine instead of Docker
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/g_scores?schema=public
