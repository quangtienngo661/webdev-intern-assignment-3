# Local API development. Use this file when running from g-scores-api/.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/g_scores?schema=public
CORS_ORIGIN=http://localhost:5173
PORT=5000

# CSV seed file path from the g-scores-api/ working directory
SEED_FILE=../dataset/diem_thi_thpt_2024.csv
SEED_BATCH_SIZE=2000
RUN_SEED_ON_START=false

# Optional seed controls
SEED_RESET=false
SEED_FORCE=false
